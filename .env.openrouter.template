###############################################################################
# Cognee + Hermes + OpenRouter
# Copy to .env and replace the value below. This is the only required secret.
###############################################################################

OPENROUTER_API_KEY="replace-with-your-openrouter-key"

###############################################################################
# Defaults below are optional. They are included so the config is explicit.
# You may delete them; cognee.hermes_openrouter applies the same defaults when
# OPENROUTER_API_KEY is present.
###############################################################################

COGNEE_LLM_PROVIDER="openai"
LLM_PROVIDER="openai"
LLM_API_KEY="${OPENROUTER_API_KEY}"
LLM_MODEL="deepseek/deepseek-chat-v3"
LLM_ENDPOINT="https://openrouter.ai/api/v1"
LITELLM_API_BASE="https://openrouter.ai/api/v1"

EMBEDDING_PROVIDER="openai"
EMBEDDING_API_KEY="${OPENROUTER_API_KEY}"
EMBEDDING_MODEL="openai/text-embedding-3-large"
EMBEDDING_ENDPOINT="https://openrouter.ai/api/v1"
EMBEDDING_DIMENSIONS=3072

COGNEE_SKIP_CONNECTION_TEST=true

# Local file-based graph/vector/runtime stores; no external DB required.
DB_PROVIDER="sqlite"
GRAPH_DATABASE_PROVIDER="kuzu"
VECTOR_DB_PROVIDER="lancedb"

# Keep runtime state near the checkout instead of inside site-packages.
DATA_ROOT_DIRECTORY=".cognee_data"
SYSTEM_ROOT_DIRECTORY=".cognee_system"
